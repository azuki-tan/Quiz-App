# =============================================
# Quiz App - Environment Variables
# Copy file này thành .env và điền giá trị thật
# File .env phải nằm cùng thư mục với docker-compose.yml
# KHÔNG commit file .env lên git!
# =============================================

# Email của tài khoản Admin (dùng Google Account)
ADMIN_EMAIL=admin@gmail.com

# Google OAuth 2.0 (tạo tại https://console.cloud.google.com/)
# Authorized redirect URI cần thêm: http://YOUR_SERVER_IP:8080/api/auth/google/callback
CLIENT_ID_SSO=xxxx.apps.googleusercontent.com
CLIENT_SECRET_SSO=GOCSPX-xxxxx

# Secret key dùng để ký JWT (tạo chuỗi ngẫu nhiên dài ít nhất 32 ký tự)
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars

# URL công khai của frontend (dùng để redirect sau khi login)
FRONTEND_URL=http://10.0.3.10:8080

# Cấu hình LiteLLM API
LITELLM_API_URL=http://10.9.0.3:8091
LITELLM_API_KEY=your_litellm_api_key_here
